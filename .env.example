# Relentless Billionaire - Environment Configuration

# Cloudflare API
CLOUDFLARE_API_TOKEN=your_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id

# D1 Database
D1_DATABASE_ID=your_d1_id

# KV Namespace
KV_NAMESPACE_ID=your_kv_id

# R2 Bucket
R2_BUCKET_NAME=relentless-billionaire-models

# Environment
ENVIRONMENT=production
BRAND=Relentless Billionaire

# Agent Settings
AGENT_LOG_LEVEL=INFO
AGENT_AUTO_FIX=true
AGENT_AUTONOMOUS_MODE=true
